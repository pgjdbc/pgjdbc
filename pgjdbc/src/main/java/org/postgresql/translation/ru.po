#: src/main/java/org/postgresql/Driver.java:259
msgid "Error loading default settings from driverconfig.properties"
msgstr ""
"Не удалось загрузить настройки по умолчанию из driverconfig.properties."

#: src/main/java/org/postgresql/Driver.java:271
#, java-format
msgid "Properties for the driver contains a non-string value for the key {0}"
msgstr "Свойства драйвера содержат нестроковое значение для ключа {0}"

#: src/main/java/org/postgresql/Driver.java:281
#, java-format
msgid "Unable to parse URL {0}"
msgstr "Не удалось разобрать URL {0}"

#: src/main/java/org/postgresql/Driver.java:316
msgid ""
"Your security policy has prevented the connection from being attempted.  You "
"probably need to grant the connect java.net.SocketPermission to the database "
"server host and port that you wish to connect to."
msgstr ""
"Политика безопасности заблокировала попытку соединения.  Выдайте "
"java.net.SocketPermission с действием connect для хоста и порта целевой БД."

# key: postgresql.unusual
#: src/main/java/org/postgresql/Driver.java:322
#: src/main/java/org/postgresql/Driver.java:404
msgid ""
"Something unusual has occurred to cause the driver to fail. Please report "
"this exception."
msgstr ""
"Драйвер столкнулся с непредвиденной ошибкой. Сообщите об этом исключении."

# key: postgresql.con.failed
#: src/main/java/org/postgresql/Driver.java:412
msgid "Connection attempt timed out."
msgstr "Истекло время ожидания подключения."

# key: postgresql.con.sslfail
#: src/main/java/org/postgresql/Driver.java:425
msgid "Interrupted while attempting to connect."
msgstr "Поток прерван во время подключения."

# key: postgresql.unimplemented
#: src/main/java/org/postgresql/Driver.java:744
#, java-format
msgid "Method {0} is not yet implemented."
msgstr "Метод {0} ещё не реализован."

#: src/main/java/org/postgresql/PGConnection.java:298
msgid "Expected a row when reading password_encryption but none was found"
msgstr "При чтении password_encryption ожидалась строка, но ничего не получено"

#: src/main/java/org/postgresql/PGConnection.java:303
msgid "SHOW password_encryption returned null value"
msgstr "SHOW password_encryption вернул значение null"

#: src/main/java/org/postgresql/PGProperty.java:1070
#: src/main/java/org/postgresql/PGProperty.java:1090
#, java-format
msgid "{0} parameter value must be an integer but was: {1}"
msgstr "Значение параметра {0} должно быть целым числом, получено: {1}"

#: src/main/java/org/postgresql/copy/CopyManager.java:50
#, java-format
msgid "Requested CopyIn but got {0}"
msgstr "Ожидался ответ CopyIn, а получен {0}"

#: src/main/java/org/postgresql/copy/CopyManager.java:61
#, java-format
msgid "Requested CopyOut but got {0}"
msgstr "Ожидался ответ CopyOut, а получен {0}"

#: src/main/java/org/postgresql/copy/CopyManager.java:72
#, java-format
msgid "Requested CopyDual but got {0}"
msgstr "Ожидался ответ CopyDual, а получен {0}"

# key: postgresql.geo.box
#: src/main/java/org/postgresql/copy/PGCopyInputStream.java:60
#, java-format
msgid "Copying from database failed: {0}"
msgstr "Не удалось скопировать данные из базы: {0}"

#: src/main/java/org/postgresql/copy/PGCopyInputStream.java:74
#: src/main/java/org/postgresql/copy/PGCopyOutputStream.java:104
msgid "This copy stream is closed."
msgstr "Поток COPY закрыт."

#: src/main/java/org/postgresql/copy/PGCopyInputStream.java:125
msgid "Read from copy failed."
msgstr "Не удалось прочитать данные из COPY."

#: src/main/java/org/postgresql/copy/PGCopyOutputStream.java:81
#, java-format
msgid "Cannot write to copy a byte of value {0}"
msgstr "Значение байта должно быть в диапазоне 0..255, передано: {0}"

#: src/main/java/org/postgresql/core/AuthMethod.java:30
#, java-format
msgid "Invalid authentication method: {0}"
msgstr "Неверный метод аутентификации: {0}"

#: src/main/java/org/postgresql/core/AuthMethod.java:51
msgid "requireAuth cannot mix positive and negative authentication methods"
msgstr ""
"В свойстве requireAuth нельзя одновременно перечислять разрешённые и "
"запрещённые методы аутентификации"

#: src/main/java/org/postgresql/core/AuthMethod.java:56
msgid "requireAuth contains duplicate authentication method"
msgstr "В свойстве requireAuth есть дублирующиеся методы аутентификации"

#: src/main/java/org/postgresql/core/AuthMethod.java:73
msgid "Authentication method is not allowed by requireAuth"
msgstr "Метод аутентификации запрещён настройкой requireAuth"

#: src/main/java/org/postgresql/core/CommandCompleteParser.java:74
#, java-format
msgid "Unable to parse the count in command completion tag: {0}."
msgstr "Не удалось разобрать число строк в теге завершения команды: {0}."

#: src/main/java/org/postgresql/core/ConnectionFactory.java:60
#, java-format
msgid "A connection could not be made using the requested protocol {0}."
msgstr "Не удалось установить соединение по запрошенному протоколу {0}."

#: src/main/java/org/postgresql/core/Oid.java:143
#, java-format
msgid "oid type {0} not known and not a number"
msgstr "Тип OID {0} неизвестен и не является числом"

#: src/main/java/org/postgresql/core/PGStream.java:732
#, java-format
msgid "Expected an EOF from server, got: {0}"
msgstr ""
"Неожиданный ответ от сервера. Ожидалось окончание потока, получен байт {0}."

#: src/main/java/org/postgresql/core/PGStream.java:840
#, java-format
msgid ""
"Result set exceeded maxResultBuffer limit. Received:  {0}; Current limit: {1}"
msgstr ""
"Результат превысил лимит maxResultBuffer. Получено: {0}; текущий лимит: {1}"

#: src/main/java/org/postgresql/core/Parser.java:1200
#, java-format
msgid "Malformed function or procedure escape syntax at offset {0}."
msgstr "Ошибка в синтаксисе JDBC-escape функции или процедуры на позиции {0}."

#: src/main/java/org/postgresql/core/ProtocolVersion.java:53
#, java-format
msgid "Invalid version number major: {0}, minor: {1}"
msgstr "Неверный номер версии: major={0}, minor={1}"

# key: postgresql.unexpected
#: src/main/java/org/postgresql/core/SetupQueryRunner.java:68
msgid "An unexpected result was returned by a query."
msgstr "Запрос вернул неожиданный результат."

#: src/main/java/org/postgresql/core/SocketFactoryFactory.java:43
#, java-format
msgid "The SocketFactory class provided {0} could not be instantiated."
msgstr "Не удалось создать SocketFactory из указанного класса {0}."

#: src/main/java/org/postgresql/core/SocketFactoryFactory.java:68
#, java-format
msgid "The SSLSocketFactory class provided {0} could not be instantiated."
msgstr "Не удалось создать SSLSocketFactory из указанного класса {0}."

#: src/main/java/org/postgresql/core/Utils.java:72
#: src/main/java/org/postgresql/core/Utils.java:89
msgid "Zero bytes may not occur in string parameters."
msgstr "Нулевой байт недопустим в строковых параметрах."

#: src/main/java/org/postgresql/core/Utils.java:99
#: src/main/java/org/postgresql/core/Utils.java:149
msgid "No IOException expected from StringBuffer or StringBuilder"
msgstr "IOException от StringBuffer или StringBuilder не ожидается."

#: src/main/java/org/postgresql/core/Utils.java:138
msgid "Zero bytes may not occur in identifiers."
msgstr "Нулевой байт недопустим в идентификаторах."

#: src/main/java/org/postgresql/core/v3/AuthenticationPluginManager.java:73
#, java-format
msgid "Unable to load Authentication Plugin {0}"
msgstr "Не удалось загрузить плагин аутентификации {0}"

#: src/main/java/org/postgresql/core/v3/AuthenticationPluginManager.java:113
#, java-format
msgid ""
"The server requested password-based authentication, but no password was "
"provided by plugin {0}"
msgstr ""
"Сервер запросил парольную аутентификацию, но плагин {0} не вернул пароль."

#: src/main/java/org/postgresql/core/v3/ChannelBinding.java:40
#, java-format
msgid "Invalid channelBinding value: {0}"
msgstr "Неверное значение параметра channelBinding: {0}"

# key: postgresql.res.colrange
#: src/main/java/org/postgresql/core/v3/CompositeParameterList.java:38
#: src/main/java/org/postgresql/core/v3/SimpleParameterList.java:60
#: src/main/java/org/postgresql/core/v3/SimpleParameterList.java:71
#: src/main/java/org/postgresql/jdbc/PgPreparedStatement.java:228
#: src/main/java/org/postgresql/jdbc/PgResultSet.java:3379
#: src/main/java/org/postgresql/jdbc/PgResultSetMetaData.java:428
#, java-format
msgid "The column index is out of range: {0}, number of columns: {1}."
msgstr "Индекс колонки вне диапазона: {0}. Допустимые значения: 1..{1}"

#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:212
msgid "User cannot be null"
msgstr "Параметр user не должен быть null"

#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:215
msgid "Database cannot be null"
msgstr "Параметр database не должен быть null"

#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:330
#, java-format
msgid "Invalid targetServerType value: {0}"
msgstr "Неверное значение параметра targetServerType: {0}"

# key: postgresql.con.refused
#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:426
#, java-format
msgid ""
"Connection to {0} refused. Check that the hostname and port are correct and "
"that the postmaster is accepting TCP/IP connections."
msgstr ""
"Подключение по адресу {0} отклонено. Проверьте, что хост и порт указаны "
"правильно и что postmaster принимает TCP/IP-соединения."

# key: postgresql.con.failed
#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:437
#: src/main/java/org/postgresql/core/v3/replication/V3ReplicationProtocol.java:140
msgid "The connection attempt failed."
msgstr "Не удалось подключиться."

#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:452
#, java-format
msgid "Could not find a server with specified targetServerType: {0}"
msgstr "Не удалось найти сервер с указанным значением targetServerType: {0}"

# key: postgresql.con.sslnotsupported
#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:594
msgid "The server does not support GSS Encoding."
msgstr "Сервер не поддерживает GSS Encoding."

# key: postgresql.con.sslnotsupported
#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:609
msgid "The server does not support GSS Encryption."
msgstr "Сервер не поддерживает GSS Encryption."

# key: postgresql.con.sslfail
#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:639
msgid "An error occurred while setting up the GSS Encoded connection."
msgstr "Ошибка при установке GSS-соединения."

# key: postgresql.con.sslnotsupported
#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:689
#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:701
msgid "The server does not support SSL."
msgstr "Сервер не поддерживает SSL."

# key: postgresql.con.sslfail
#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:715
msgid "An error occurred while setting up the SSL connection."
msgstr "Ошибка при установке SSL-соединения."

#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:849
msgid ""
"Channel binding is required, but server skipped authentication. Channel "
"binding is only supported with SCRAM authentication over encrypted "
"connections."
msgstr ""
"Требуется channel binding, но сервер пропустил аутентификацию. Channel "
"binding поддерживается только с аутентификацией SCRAM по зашифрованному "
"соединению."

#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:855
#, java-format
msgid ""
"Channel binding is required, but server requested ''{0}'' authentication. "
"Channel binding is only supported with SCRAM authentication over encrypted "
"connections."
msgstr ""
"Требуется channel binding, но сервер запросил аутентификацию ''{0}''. "
"Channel binding поддерживается только с аутентификацией SCRAM по "
"зашифрованному соединению."

#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:1002
#, java-format
msgid "{0} must be a non-negative integer, but was: {1}"
msgstr "Значение {0} должно быть неотрицательным целым числом, получено: {1}"

#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:1010
msgid ""
"The server requested SCRAM-based authentication, but no password was "
"provided."
msgstr "Сервер запросил аутентификацию SCRAM, но пароль не указан."

#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:1016
msgid ""
"The server requested SCRAM-based authentication, but the password is an "
"empty string."
msgstr "Сервер запросил аутентификацию SCRAM, но пароль пуст."

# key: postgresql.con.auth
#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:1051
#, java-format
msgid ""
"The authentication type {0} is not supported. Check that you have configured "
"the pg_hba.conf file to include the client''s IP address or subnet, and that "
"it is using an authentication scheme supported by the driver."
msgstr ""
"Тип аутентификации {0} не поддерживается. Убедитесь, что файл pg_hba.conf "
"настроен на приём IP-адреса или подсети клиента, а также использует схему "
"аутентификации, поддерживаемую драйвером."

# key: postgresql.con.setup
#: src/main/java/org/postgresql/core/v3/ConnectionFactoryImpl.java:1058
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:3087
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:3091
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:3167
#: src/main/java/org/postgresql/gss/GssAction.java:165
msgid "Protocol error.  Session setup failed."
msgstr "Ошибка протокола.  Не удалось установить сессию."

#: src/main/java/org/postgresql/core/v3/CopyInImpl.java:58
msgid "CopyIn copy direction can't receive data"
msgstr "Операция CopyIn не может получать данные"

#: src/main/java/org/postgresql/core/v3/CopyOperationImpl.java:65
#, java-format
msgid "CommandComplete expected COPY but got: {0}"
msgstr "В CommandComplete ожидалось COPY, получено: {0}"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:274
msgid "Tried to obtain lock while already holding it"
msgstr "Попытка захватить блокировку, которая уже удерживается"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:290
msgid "Tried to break lock on database connection"
msgstr "Попытка снять блокировку соединения с БД"

# key: postgresql.con.sslfail
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:308
msgid "Interrupted while waiting to obtain lock on database connection"
msgstr "Поток прерван во время ожидания блокировки соединения с БД."

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:459
msgid "Unable to bind parameter values for statement."
msgstr "Не удалось привязать значения параметров к запросу."

# key: postgresql.con.ioerror
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:465
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:692
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:784
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:834
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:965
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:2835
#: src/main/java/org/postgresql/util/StreamWrapper.java:86
msgid "An I/O error occurred while sending to the backend."
msgstr "Ошибка ввода/вывода при отправке бэкенду."

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:544
msgid "Error releasing savepoint"
msgstr "Ошибка при освобождении точки сохранения"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:749
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:803
#, java-format
msgid "Expected command status BEGIN, got {0}."
msgstr "Ожидался статус команды BEGIN, но получен {0}."

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:808
#: src/main/java/org/postgresql/jdbc/PgResultSet.java:2204
#, java-format
msgid "Unexpected command status: {0}."
msgstr "Неожиданный статус команды: {0}."

# key: postgresql.con.ioerror
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:923
msgid "An error occurred while trying to get the socket timeout."
msgstr "Ошибка при попытке получить таймаут сокета."

# key: postgresql.con.type
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:958
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1049
#, java-format
msgid "Unknown Response Type {0}."
msgstr "Неизвестный тип ответа {0}."

# key: postgresql.con.ioerror
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:982
msgid "An error occurred while trying to reset the socket timeout."
msgstr "Ошибка при попытке сбросить таймаут сокета."

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1102
msgid "Database connection failed when starting copy"
msgstr "Сбой соединения с БД при запуске COPY"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1140
msgid "Tried to cancel an inactive copy operation"
msgstr "Попытка отменить неактивную операцию COPY"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1179
msgid "Database connection failed when canceling copy operation"
msgstr "Сбой соединения с БД при отмене операции COPY"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1195
msgid "Missing expected error response to copy cancel request"
msgstr "Ожидался ответ с ошибкой на запрос отмены COPY, но он не получен"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1199
#, java-format
msgid "Got {0} error responses to single copy cancel request"
msgstr "На один запрос отмены COPY получено ответов с ошибкой: {0}"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1215
msgid "Tried to end inactive copy"
msgstr "Попытка завершить неактивную операцию COPY"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1230
msgid "Database connection failed when ending copy"
msgstr "Сбой соединения с БД при завершении COPY"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1256
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1288
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1312
msgid "Tried to write to an inactive copy operation"
msgstr "Попытка записи в неактивную операцию COPY"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1270
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1303
#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1322
msgid "Database connection failed when writing to copy"
msgstr "Сбой соединения с БД при записи в COPY"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1339
msgid "Tried to read from inactive copy"
msgstr "Попытка чтения из неактивной операции COPY"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1351
msgid "Database connection failed when reading from copy"
msgstr "Сбой соединения с БД при чтении из COPY"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1376
msgid "PGStream is closed"
msgstr "PGStream закрыт."

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1435
#, java-format
msgid "Received CommandComplete ''{0}'' without an active copy operation"
msgstr "Получен CommandComplete ''{0}'' без активной операции COPY"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1460
#, java-format
msgid "Got CopyInResponse from server during an active {0}"
msgstr "Получен CopyInResponse от сервера во время активной операции {0}"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1474
#, java-format
msgid "Got CopyOutResponse from server during an active {0}"
msgstr "Получен CopyOutResponse от сервера во время активной операции {0}"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1488
#, java-format
msgid "Got CopyBothResponse from server during an active {0}"
msgstr "Получен CopyBothResponse от сервера во время активной операции {0}"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1507
msgid "Got CopyData without an active copy operation"
msgstr "Получены данные CopyData без активной операции COPY"

#: src/main/java/org/postgresql/core/v3/QueryExecutorImpl.java:1511
