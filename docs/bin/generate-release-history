#!/usr/bin/env bash
# Generate docs/data/release-history.yaml from local git tags.
#
# Usage: docs/bin/generate-release-history [<repo-root>]
#
# Reads REL42.* release tags, groups them by minor line, merges with
# docs/data/release-history-overlay.yaml for classifier builds (.jre6/.jre7),
# and writes docs/data/release-history.yaml.
#
# Requires: git, awk — no other dependencies.

set -euo pipefail

REPO_ROOT="${1:-$(cd "$(dirname "$0")/../.." && pwd)}"
OVERLAY="$REPO_ROOT/docs/data/release-history-overlay.yaml"
OUTPUT="$REPO_ROOT/docs/data/release-history.yaml"

# Emit every REL42.X.Y tag (no RC/alpha/beta) as "42.X.Y YYYY-MM-DD",
# sorted by version ascending.
git -C "$REPO_ROOT" tag -l 'REL42.*' \
    --sort=version:refname \
    --format='%(refname:strip=2) %(creatordate:format:%Y-%m-%d)' \
  | grep -v -i 'rc\|alpha\|beta' \
  | sed 's/^REL//' \
  | awk -v overlay="$OVERLAY" -v output="$OUTPUT" '
BEGIN {
    branch_count = 0
}

# Input lines: "42.X.Y YYYY-MM-DD"
{
    ver  = $1
    date = $2

    # Derive branch id: "42.X.Y" -> "42.X.x"
    n = split(ver, parts, ".")
    branch = parts[1] "." parts[2] ".x"

    if (!(branch in branch_idx)) {
        branch_idx[branch] = branch_count
        branches[branch_count] = branch
        branch_count++
    }
    b = branch_idx[branch]

    if (first_ver[b] == "") first_ver[b] = ver
    last_ver[b]  = ver
    last_date[b] = date

    # Store date keyed by version for classifier lookup
    date_by_ver[ver] = date
}

END {
    # Parse the overlay file for classifier rows (.jre6/.jre7).
    # Format we look for:
    #   - id: jre7
    #     branch: 42.2.x
    #     last_version: 42.2.29
    c_count = 0
    while ((getline line < overlay) > 0) {
        if (line ~ /^[ \t]*-[ \t]+id:/) {
            sub(/.*id:[ \t]*/, "", line)
            c_id[c_count] = line
        } else if (line ~ /^[ \t]+branch:/) {
            sub(/.*branch:[ \t]*/, "", line)
            c_branch[c_count] = line
        } else if (line ~ /^[ \t]+last_version:/) {
            sub(/.*last_version:[ \t]*/, "", line)
            c_lastver[c_count] = line
            c_count++
        }
    }
    close(overlay)

    # Write output
    print "# Generated by docs/bin/generate-release-history — DO NOT EDIT."  > output
    print "# Source of truth: git tags (REL42.*)"                            >> output
    print "#                  + docs/data/release-history-overlay.yaml."     >> output
    print "# Run \`docs/bin/generate-release-history\` to regenerate."       >> output
    print ""                                                                  >> output
    print "rows:"                                                             >> output

    row_count = 0
    for (i = branch_count - 1; i >= 0; i--) {
        b      = i
        branch = branches[i]
        fv     = first_ver[b]
        lv     = last_ver[b]
        ld     = last_date[b]
        vrange = (fv == lv) ? lv : fv "-" lv

        print "- release_line: \"" branch "\""  >> output
        print "  version_range: \"" vrange "\""  >> output
        print "  released: \"" ld "\""           >> output
        row_count++

        # Append classifier rows for this branch, sorted by date desc
        # Collect matching classifiers first
        n_c = 0
        for (j = 0; j < c_count; j++) {
            if (c_branch[j] == branch) {
                cv = c_lastver[j]
                cd = (cv in date_by_ver) ? date_by_ver[cv] : ""
                c_rows_ver[n_c]  = cv "." c_id[j]
                c_rows_date[n_c] = cd
                n_c++
            }
        }
        # Insertion-sort classifiers by date descending (n_c is tiny)
        for (a = 1; a < n_c; a++) {
            kv = c_rows_ver[a]; kd = c_rows_date[a]
            b2 = a - 1
            while (b2 >= 0 && c_rows_date[b2] < kd) {
                c_rows_ver[b2+1]  = c_rows_ver[b2]
                c_rows_date[b2+1] = c_rows_date[b2]
                b2--
            }
            c_rows_ver[b2+1]  = kv
            c_rows_date[b2+1] = kd
        }
        for (a = 0; a < n_c; a++) {
            print "- release_line: \"" branch "\""        >> output
            print "  version_range: \"" c_rows_ver[a] "\"" >> output
            print "  released: \"" c_rows_date[a] "\""    >> output
            row_count++
        }
        # Clear classifier scratch arrays for next branch
        for (a = 0; a < n_c; a++) { delete c_rows_ver[a]; delete c_rows_date[a] }
    }

    print "Wrote " row_count " release-history rows to " output > "/dev/stderr"
}
'